# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored.

# The only header the public API actually requires:
VITE_TACTICUS_API_KEY=your-api-key-uuid

# Extra identifiers the user was given; currently unused by the public API
# but stored in case any endpoint starts requiring them.
VITE_SNOWPRINT_ID=
VITE_USER_ID=
VITE_PRINCIPAL=

# Optional: URL of a Cloudflare Worker proxy that forwards /api/v1/* to
# api.tacticusgame.com with CORS headers. See cloudflare-worker/README.md.
# Leave empty in dev (the Vite proxy handles it); set this for production
# builds if you want the hosted site to call the API directly from the browser.
VITE_API_BASE=
