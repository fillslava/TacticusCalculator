# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored.

# The only header the public API actually requires:
VITE_TACTICUS_API_KEY=your-api-key-uuid

# Extra identifiers the user was given; currently unused by the public API
# but stored in case any endpoint starts requiring them.
VITE_SNOWPRINT_ID=
VITE_USER_ID=
VITE_PRINCIPAL=
